# ---------------------------------------------------------------------------
# Pipeline environment variables — copy to .env and fill in real values.
# Never commit .env to source control.
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# Azure Blob Storage  (used by azure/blob_client.py)
# Full URL of the storage account, e.g. https://<account>.blob.core.windows.net
# ---------------------------------------------------------------------------
AZURE_BLOB_ACCOUNT_URL=https://<storage-account-name>.blob.core.windows.net

# ---------------------------------------------------------------------------
# Azure Cosmos DB  (used by azure/cosmos_client.py)
# Full endpoint URI, e.g. https://<account>.documents.azure.com:443/
# ---------------------------------------------------------------------------
COSMOS_ENDPOINT=https://<cosmos-account>.documents.azure.com:443/

# ---------------------------------------------------------------------------
# Data paths  (used by utils/helpers_matching.py and configs/config_matching.py)
# container_name   : name of the blob container AND the top-level data folder
# data_root_abs_path : absolute path on the local machine where data lives;
#                     combined with container_name to give root_dir
# ---------------------------------------------------------------------------
container_name=elephant-images
data_root_abs_path=/mnt/data

# ---------------------------------------------------------------------------
# BTEH data roots  (used by configs/config_bteh.py and BTEH pipeline scripts)
# BTEH_SOURCE_ROOT   : absolute path to the read-only BTEH image tree.
#                      Default: <repo-parent>/shared/BTEH
# BTEH_ARTIFACT_ROOT : absolute path to the writable versioned artifact tree.
#                      Default: <repo-parent>/shared/BTEH_reid_artifacts
# These must never point to the same directory.
# ---------------------------------------------------------------------------
BTEH_SOURCE_ROOT=/path/to/BTEH
BTEH_ARTIFACT_ROOT=/path/to/BTEH_reid_artifacts

# ELPephants benchmark roots. Source and artifacts must remain separate.
ELPEPHANTS_SOURCE_ROOT=/path/to/ELPephants
ELPEPHANTS_ARTIFACT_ROOT=/path/to/ELPephants_reid_artifacts

# ---------------------------------------------------------------------------
# Azure Blob mount / Streamlit app  (used by app.py)
# storage_account_name : storage account name (without .blob.core.windows.net)
# mount_type           : blobfuse2 mount driver type, e.g. "blobfuse2"
# app_id               : Azure AD application (client) ID used for mounting
# ---------------------------------------------------------------------------
storage_account_name=<storage-account-name>
mount_type=blobfuse2
app_id=<azure-ad-app-client-id>

# ---------------------------------------------------------------------------
# User authentication  (used by user_authentication.py)
# authenticate_users : set to "True" to enable MSAL login gate, "False" to skip
# client_id          : Azure AD application (client) ID for MSAL OAuth flow
# tenant_id          : Azure AD tenant (directory) ID
# redirect_uri       : OAuth redirect URI registered in the Azure AD app
# key_vault_url      : Azure Key Vault URL that holds the client secret
# secret_name        : name of the Key Vault secret containing the client secret
# ---------------------------------------------------------------------------
authenticate_users=False
client_id=<azure-ad-client-id>
tenant_id=<azure-ad-tenant-id>
redirect_uri=http://localhost:8501
key_vault_url=https://<key-vault-name>.vault.azure.net/
secret_name=<key-vault-secret-name>
